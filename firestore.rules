rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user owns the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Helper function to check if user is admin
    function isAdmin() {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // Users collection - users can read/write their own document
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }
    
    // Elder profiles - elderly users can manage their own profile
    match /elder_profiles/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }
    
    // Volunteer profiles - volunteers can manage their own profile
    match /volunteer_profiles/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }
    
    // Organizations - organization admins can manage their profile
    match /organizations/{orgId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == orgId;
      allow update: if isAuthenticated() && (request.auth.uid == orgId || isAdmin());
      allow delete: if isAdmin();
    }
    
    // Requests collection - elderly can create, volunteers can view/accept
    // Backend uses 'requests' collection
    match /requests/{requestId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && 
                    request.resource.data.elderlyId == request.auth.uid;
      allow update: if isAuthenticated() && 
                    (resource.data.elderlyId == request.auth.uid || 
                     resource.data.volunteerId == request.auth.uid ||
                     resource.data.status == 'pending' ||
                     isAdmin());
      allow delete: if isAuthenticated() && 
                    (resource.data.elderlyId == request.auth.uid || isAdmin());
    }
    
    // Volunteer hours log
    match /volunteer_hours/{hourId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
